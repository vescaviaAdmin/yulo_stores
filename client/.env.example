# Copy to .env and adjust. Controls the data layer (src/api/config.js).

# true  -> use in-app mock JSON (src/mocks), no backend needed (default)
# false -> use the real backend
VITE_USE_MOCKS=true

# Fake network delay for mock responses, in ms.
VITE_MOCK_LATENCY=250

# Prefix for real requests. Leave blank to use the Vite dev proxy in vite.config.js.
# VITE_API_BASE=
